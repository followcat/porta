APP_NAME=Porta
ENV=dev
DEBUG=true
SECRET_KEY=replace-with-a-long-random-string
PORTA_MASTER_KEY=replace-with-a-long-random-string
PORTA_MASTER_KEY_VERSION=v1
MYSQL_DSN=mysql+pymysql://porta:porta@127.0.0.1:3306/porta?charset=utf8mb4
SSH_BIN=/usr/bin/ssh
SSHPASS_BIN=/usr/bin/sshpass
SUPERVISOR_LOOP_SECONDS=3
TUNNEL_STARTUP_GRACE_SECONDS=2
SESSION_COOKIE_NAME=porta_session
AUTO_CREATE_TABLES=false
